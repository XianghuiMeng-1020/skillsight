DATABASE_URL=postgresql+psycopg2://skillsight:skillsight_pw@localhost:5432/skillsight
REDIS_HOST=localhost
REDIS_PORT=56379
SKILLSIGHT_AUTH_SECRET=your-secret-change-in-production
SKILLSIGHT_ENV=development
# When SKILLSIGHT_ENV=production, dev_login is disabled unless set to 1/true (demo only).
# SKILLSIGHT_ALLOW_DEV_LOGIN=true
# Include your frontend origin(s). Production example:
# CORS_ALLOWED_ORIGINS=http://localhost:3000,https://skillsight-230.pages.dev,https://skillsight.pages.dev
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
BFF_BACKEND_URL=http://127.0.0.1:8001
# Production: LLM (OpenAI) + Qdrant Cloud
# Provider priority: OPENAI_API_KEY first, then OPENROUTER_API_KEY as fallback.
# At least one of the two must be set for the assessment agent to work.
LLM_PROVIDER=openai
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
# OpenRouter fallback (https://openrouter.ai/keys) — used when OPENAI_API_KEY is empty.
OPENROUTER_API_KEY=
# Default free model (no credits needed): meta-llama/llama-3.1-8b-instruct:free
# Paid alternatives: openai/gpt-4o-mini, anthropic/claude-3-haiku
OPENROUTER_MODEL=meta-llama/llama-3.1-8b-instruct:free
OPENROUTER_SITE_URL=https://skillsight-230.pages.dev
OPENROUTER_SITE_NAME=SkillSight
QDRANT_URL=
QDRANT_API_KEY=
RATE_LIMIT_ENABLED=false
