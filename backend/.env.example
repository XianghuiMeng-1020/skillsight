DATABASE_URL=postgresql+psycopg2://skillsight:skillsight_pw@localhost:5432/skillsight
REDIS_HOST=localhost
REDIS_PORT=56379
SKILLSIGHT_AUTH_SECRET=your-secret-change-in-production
SKILLSIGHT_ENV=development
# When SKILLSIGHT_ENV=production, dev_login is disabled unless set to 1/true (demo only).
# SKILLSIGHT_ALLOW_DEV_LOGIN=true
# Include your frontend origin(s). Production example:
# CORS_ALLOWED_ORIGINS=http://localhost:3000,https://skillsight-230.pages.dev,https://skillsight.pages.dev
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
BFF_BACKEND_URL=http://127.0.0.1:8001
# Production: LLM (OpenAI) + Qdrant Cloud
LLM_PROVIDER=openai
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
QDRANT_URL=
QDRANT_API_KEY=
RATE_LIMIT_ENABLED=false
