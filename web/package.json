{
  "name": "web",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "test:e2e": "playwright test tests/e2e/student_golden_path.spec.ts --reporter=list",
    "test:e2e:headed": "playwright test tests/e2e/student_golden_path.spec.ts --headed",
    "test:e2e:workflows": "playwright test tests/e2e/student_workflows_full.spec.ts --reporter=list",
    "test:e2e:workflows:prod": "npm run build && E2E_USE_PROD=1 playwright test tests/e2e/student_workflows_full.spec.ts --reporter=list",
    "test:e2e:i18n-screenshots": "playwright test tests/e2e/i18n_route_screenshot_regression.spec.ts --reporter=list"
  },
  "dependencies": {
    "html2canvas": "^1.4.1",
    "next": "16.1.1",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "recharts": "^3.7.0",
    "styled-jsx": "^5.1.6"
  },
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "16.1.1",
    "typescript": "5.9.3"
  }
}
